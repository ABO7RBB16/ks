-- ══════════════════════════════════════════
--  🧹 تنظيف ذاكرة السيرفر
-- ══════════════════════════════════════════
local function getServerMemory()
	return math.floor(Stats:GetTotalMemoryUsageMb())
end

local function cleanServerMemory()
	local before = getServerMemory()

	-- 1. تنظيف الـ Instances المنتهية الصلاحية في Workspace
	local cleaned = 0
	local now = os.clock()

	for _, obj in ipairs(workspace:GetDescendants()) do
		-- حذف الـ Parts العشوائية القديمة (لا اسم لها أو اسمها "Part")
		if obj:IsA("BasePart") then
			if not obj.Anchored
				and obj.Parent == workspace
				and (obj.Name == "Part" or obj.Name == "Handle" or obj.Name == "Effect")
			then
				-- تحقق من عمرها باستخدام Attribute
				local birthTime = obj:GetAttribute("BirthTime")
				if birthTime and (now - birthTime) > CONFIG.PART_AGE_LIMIT then
					obj:Destroy()
					cleaned += 1
				elseif not birthTime then
					obj:SetAttribute("BirthTime", now)
				end
			end
		end

		-- حذف الـ Sounds المنتهية
		if obj:IsA("Sound") and not obj.IsPlaying and obj:GetAttribute("AutoClean") then
			obj:Destroy()
			cleaned += 1
		end

		-- حذف الـ Particles المتوقفة
		if obj:IsA("ParticleEmitter") and obj:GetAttribute("AutoClean") then
			if obj.Enabled == false then
				obj:Destroy()
				cleaned += 1
			end
		end
	end

	-- 2. تنظيف الـ Tweens المنتهية (يتم عبر الـ Connections Manager)
	-- 3. فرض جمع القمامة (Lua GC)
	collectgarbage("collect")
	collectgarbage("collect") -- مرتين للتأكد

	local after = getServerMemory()
	local freed = math.max(0, before - after)
	totalCleaned += freed

	if cleaned > 0 or freed > 0 then
		log(string.format("تم تنظيف الذاكرة | قبل: %d MB | بعد: %d MB | محرر: %d MB | عناصر محذوفة: %d",
			before, after, freed, cleaned), "CLEAN")
	end

	-- تحذير إذا تجاوزت الذاكرة الحد
	if after > CONFIG.MEMORY_CRITICAL_THRESHOLD then
		log(string.format("خطر! استخدام الذاكرة: %d MB - يتجاوز الحد الحرج!", after), "CRITICAL")
		-- إجراء طارئ: تنظيف مكثف
		for _, player in ipairs(Players:GetPlayers()) do
			player:LoadCharacter() -- إعادة تحميل الشخصيات لتقليل الحمل
		end
	elseif after > CONFIG.MEMORY_WARNING_THRESHOLD then
		log(string.format("تحذير! استخدام الذاكرة: %d MB", after), "WARN")
	end

	lastMemoryUsage = after
end

-- ══════════════════════════════════════════
--  👤 تحسين أداء اللاعبين
-- ══════════════════════════════════════════
local function optimizePlayer(player)
	local character = player.Character
	if not character then return end

	local cleaned = 0

	-- 1. حذف الـ Parts غير الضرورية من الشخصية
	for _, obj in ipairs(character:GetDescendants()) do
		-- حذف الـ Accessories المكررة
		if obj:IsA("Accessory") then
			local handle = obj:FindFirstChild("Handle")
			if handle then
				-- تبسيط الـ mesh إن أمكن
				if handle:FindFirstChildOfClass("SpecialMesh") then
					-- إبقاؤه لكن تقليل تعقيده
				end
			end
		end

		-- حذف الـ Decals الزائدة
		if obj:IsA("Decal") and obj:GetAttribute("Removable") then
			obj:Destroy()
			cleaned += 1
		end

		-- إيقاف الـ Particles عند بُعد اللاعب
		if obj:IsA("ParticleEmitter") and obj:GetAttribute("LOD_Disable") then
			obj.Enabled = false
		end
	end

	-- 2. تحسين الـ Humanoid
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		-- تفعيل تحسينات الـ Humanoid
		humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
		humanoid:SetStateEnabled(Enum.HumanoidStateType.Flying, false)
		humanoid.AutoRotate = true
	end

	-- 3. تنظيف الـ Scripts الميتة داخل الشخصية
	for _, script in ipairs(character:GetDescendants()) do
		if (script:IsA("LocalScript") or script:IsA("Script"))
			and not script.Enabled
			and script:GetAttribute("AutoClean")
		then
			script:Destroy()
			cleaned += 1
		end
	end

	if cleaned > 0 then
		log(string.format("تحسين شخصية '%s' | محذوف: %d عنصر", player.Name, cleaned), "CLEAN")
	end
end

local function optimizeAllPlayers()
	for _, player in ipairs(Players:GetPlayers()) do
		pcall(optimizePlayer, player)
	end
end

-- ══════════════════════════════════════════
--  🔗 منع تسرب الـ Connections
-- ══════════════════════════════════════════
local function setupPlayerConnectionTracking(player)
	-- إنشاء مدير خاص بكل لاعب
	playerData[player.UserId] = {
		connections = ConnectionManager.new(player.Name),
		joinTime    = os.clock(),
		name        = player.Name,
	}

	local pData = playerData[player.UserId]

	-- تتبع الشخصية
	pData.connections:add(
		player.CharacterAdded:Connect(function(character)
			-- تنظيف بعد تحميل الشخصية
			task.delay(3, function()
				pcall(optimizePlayer, player)
			end)
		end),
		"CharacterAdded"
	)

	log(string.format("تم تتبع اللاعب: %s (ID: %d)", player.Name, player.UserId))
end

local function cleanupPlayerData(player)
	local pData = playerData[player.UserId]
	if pData then
		local count = pData.connections:disconnectAll()
		playerData[player.UserId] = nil
		log(string.format("تم تنظيف بيانات '%s' | قطع Connections: %d", player.Name, count), "CLEAN")
	end
end

-- ══════════════════════════════════════════
--  🗑️  نظام تنظيف المخلفات المتقدم
-- ══════════════════════════════════════════
local function cleanDebris()
	local cleaned = 0

	-- البحث عن العناصر المميزة للحذف التلقائي
	local function searchAndClean(parent)
		for _, obj in ipairs(parent:GetChildren()) do
			if obj:GetAttribute("AutoDestroy") == true then
				obj:Destroy()
				cleaned += 1
			elseif obj:IsA("Model") and #obj:GetChildren() == 0 then
				-- نماذج فارغة
				if obj:GetAttribute("AllowEmpty") ~= true then
					obj:Destroy()
					cleaned += 1
				end
			elseif obj:IsA("Folder") and #obj:GetChildren() == 0 then
				if obj:GetAttribute("KeepEmpty") ~= true then
					-- إبقاء المجلدات الفارغة المقصودة
				end
			else
				-- لا تنظيف داخل شخصيات اللاعبين
				local isPlayerChar = false
				for _, p in ipairs(Players:GetPlayers()) do
					if p.Character == obj then
						isPlayerChar = true
						break
					end
				end
				if not isPlayerChar then
					searchAndClean(obj)
				end
			end
		end
	end

	pcall(searchAndClean, workspace)

	if cleaned > 0 then
		log(string.format("تنظيف المخلفات: تم حذف %d عنصر", cleaned), "CLEAN")
	end
end

-- ══════════════════════════════════════════
--  📊 تقرير الأداء
-- ══════════════════════════════════════════
local function printReport()
	local mem    = getServerMemory()
	local players = Players:GetPlayers()
	local connCount = 0

	for _, pData in pairs(playerData) do
		connCount += pData.connections._count
	end

	print("═══════════════════════════════════════════")
	print("📊  تقرير أداء السيرفر")
	print("═══════════════════════════════════════════")
	print(string.format("🕐 الوقت        : %s", os.date("%Y-%m-%d %H:%M:%S")))
	print(string.format("💾 ذاكرة السيرفر: %d MB", mem))
	print(string.format("👥 اللاعبين     : %d", #players))
	print(string.format("🔗 Connections  : %d", connCount))
	print(string.format("🧹 مجموع المحرر : %d MB", totalCleaned))
	print(string.format("📡 Ping متوسط  : ~%d ms",
		#players > 0 and math.floor(Players:GetPlayers()[1]:GetNetworkPing() * 1000) or 0))

	-- حالة الذاكرة
	local status
	if mem < 800 then
		status = "✅ ممتازة"
	elseif mem < CONFIG.MEMORY_WARNING_THRESHOLD then
		status = "🟡 جيدة"
	elseif mem < CONFIG.MEMORY_CRITICAL_THRESHOLD then
		status = "🟠 مرتفعة"
	else
		status = "🔴 حرجة"
	end
	print(string.format("⚡ حالة الذاكرة : %s", status))
	print("═══════════════════════════════════════════")
end

