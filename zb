-- ══════════════════════════════════════════
--  🚀 بدء تشغيل النظام
-- ══════════════════════════════════════════
local function initialize()
	log("═══════════════════════════════════════")
	log("  🚀 بدء تشغيل نظام التحسين والتنظيف  ")
	log("═══════════════════════════════════════")

	-- تطبيق الإعدادات
	applyServerOptimizations()

	-- تتبع اللاعبين الحاليين
	for _, player in ipairs(Players:GetPlayers()) do
		setupPlayerConnectionTracking(player)
	end

	-- ── ربط أحداث اللاعبين ──
	serverConnections:add(
		Players.PlayerAdded:Connect(setupPlayerConnectionTracking),
		"PlayerAdded"
	)

	serverConnections:add(
		Players.PlayerRemoving:Connect(function(player)
			task.delay(1, function()
				cleanupPlayerData(player)
			end)
		end),
		"PlayerRemoving"
	)

	-- ── تنظيف الذاكرة الدوري ──
	task.spawn(function()
		while true do
			task.wait(CONFIG.MEMORY_CLEAN_INTERVAL)
			pcall(cleanServerMemory)
		end
	end)

	-- ── تنظيف المخلفات الدوري ──
	task.spawn(function()
		while true do
			task.wait(CONFIG.DEBRIS_CLEAN_INTERVAL)
			pcall(cleanDebris)
		end
	end)

	-- ── تحسين اللاعبين الدوري ──
	task.spawn(function()
		while true do
			task.wait(CONFIG.PLAYER_OPTIMIZE_INTERVAL)
			pcall(optimizeAllPlayers)
		end
	end)

	-- ── تقارير الأداء ──
	task.spawn(function()
		while true do
			task.wait(CONFIG.REPORT_INTERVAL)
			pcall(printReport)
		end
	end)

	-- تنظيف أولي فوري
	task.delay(5, function()
		pcall(cleanServerMemory)
		pcall(cleanDebris)
		pcall(optimizeAllPlayers)
		log("✅ اكتمل التنظيف الأولي للسيرفر")
	end)

	log("✅ النظام يعمل بنجاح!")
	log(string.format("   🔄 تنظيف الذاكرة : كل %d ثانية", CONFIG.MEMORY_CLEAN_INTERVAL))
	log(string.format("   🗑️  تنظيف المخلفات: كل %d ثانية", CONFIG.DEBRIS_CLEAN_INTERVAL))
	log(string.format("   👤 تحسين اللاعبين: كل %d ثانية", CONFIG.PLAYER_OPTIMIZE_INTERVAL))
	log(string.format("   📊 تقرير الأداء  : كل %d ثانية", CONFIG.REPORT_INTERVAL))
end

-- تشغيل النظام مع حماية من الأخطاء
local success, err = pcall(initialize)
if not success then
	warn("❌ [OPTIMIZER] فشل تشغيل النظام: " .. tostring(err))
end

