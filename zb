-- ══════════════════════════════════
--  🖨️  نظام السجل
-- ══════════════════════════════════
local function log(msg, level)
	if not CONFIG.LOG_ENABLED then return end
	level = level or "INFO"
	local prefix = {
		INFO     = "✅ [OPTIMIZER]",
		WARN     = "⚠️  [OPTIMIZER]",
		ERROR    = "❌ [OPTIMIZER]",
		CRITICAL = "🚨 [OPTIMIZER]",
		CLEAN    = "🧹 [OPTIMIZER]",
	}
	print(string.format("%s [%s] %s", prefix[level] or "[OPTIMIZER]", os.date("%H:%M:%S"), msg))
end

-- ══════════════════════════════════════════
--  🛡️  إدارة الـ Connections لمنع التسرب
-- ══════════════════════════════════════════
local ConnectionManager = {}
ConnectionManager.__index = ConnectionManager

function ConnectionManager.new(owner)
	return setmetatable({
		_owner       = owner or "Unknown",
		_connections = {},
		_count       = 0,
	}, ConnectionManager)
end

function ConnectionManager:add(connection, name)
	if connection and typeof(connection) == "RBXScriptConnection" then
		name = name or ("conn_" .. self._count)
		self._connections[name] = connection
		self._count += 1
		return connection
	end
	return nil
end

function ConnectionManager:remove(name)
	if self._connections[name] then
		pcall(function()
			self._connections[name]:Disconnect()
		end)
		self._connections[name] = nil
		self._count -= 1
	end
end

function ConnectionManager:disconnectAll()
	local count = 0
	for name, conn in pairs(self._connections) do
		pcall(function()
			conn:Disconnect()
		end)
		self._connections[name] = nil
		count += 1
	end
	self._count = 0
	return count
end

